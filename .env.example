# ============================================================
# Social Branding Agent — Environment Variables
# Copy this to .env and fill in your keys.
# All keys are free-tier eligible except ANTHROPIC_API_KEY (optional, polish mode).
# ============================================================

# --- LLM Providers ---

# Groq — free tier, no credit card. Sign up at console.groq.com
GROQ_API_KEY=

# Google AI Studio — free tier. Sign up at aistudio.google.com
GEMINI_API_KEY=

# Anthropic — optional, for polish mode and failsafe tier
# Get from console.anthropic.com. If empty, polish mode is disabled.
ANTHROPIC_API_KEY=

# --- Research ---

# Tavily — 1000 free searches/month. Sign up at tavily.com
TAVILY_API_KEY=

# --- Notifications ---

# ntfy.sh topic — auto-generated on first run if empty.
# This is your private channel. Anyone with this string can publish.
NTFY_TOPIC=

# --- Observability (optional) ---

# LangSmith — free tier. Helps trace agent runs visually.
# Get from smith.langchain.com. Disable by leaving empty.
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=social-branding-agent

# --- App Settings ---

# Override default storage location (otherwise: ~/.social-branding-agent/)
# APP_DATA_DIR=

# Backend port (default 8000)
# BACKEND_PORT=8000